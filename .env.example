# GitHub source
REPO_OWNER=pedroccpimenta
REPO_NAME=datafiles
REPO_FOLDER=aqualog
REPO_BRANCH=master

# If repo is private, set a personal access token
GITHUB_TOKEN=

# Optional: use a Colab secret name (JSON payload with {"key": "ghp_..."})
GITHUB_SECRET_NAME=
USER_ACRONYM=

# Optional: bypass folder listing and read direct JSON URLs
JSON_FILE_URLS=

# Output and runtime
OUTPUT_FOLDER=./output_water
REQUEST_TIMEOUT=30

# Email reporting (opcional)
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=recipient@example.com
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
